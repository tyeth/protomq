{
  "name": "Feather S2 SH1107 128x64 OLED Demo",
  "description": "Tests SH1107 128x64 I2C OLED FeatherWing on Adafruit Feather ESP32-S2. Responds to checkin, configures the OLED at 0x3C, then writes test messages.",
  "protoVersion": "v2",
  "steps": [
    {
      "name": "checkin-response",
      "description": "Respond to device checkin with OK and board capabilities",
      "trigger": "checkin.request",
      "response": {
        "checkin": {
          "response": {
            "response": "R_OK",
            "totalGpioPins": 20,
            "totalAnalogPins": 4,
            "referenceVoltage": 2.5,
            "componentAdds": {},
            "sleepEnabled": false
          }
        }
      }
    },
    {
      "name": "add-display",
      "description": "Configure the 128x64 SH1107 OLED FeatherWing via I2C at 0x3C",
      "after": "checkin-response",
      "waitFor": "checkin.complete",
      "delay": 500,
      "topic": "display",
      "send": {
        "display": {
          "add": {
            "type": "DISPLAY_CLASS_OLED",
            "driver": "SH1107",
            "panel": "oled128x64default",
            "name": "oled128x64default",
            "i2c": {
              "deviceAddress": 60,
              "busSda": "D3",
              "busScl": "D4"
            },
            "configDisplay": {
              "width": 128,
              "height": 64,
              "textSize": 1
            },
            "write": {
              "name": "oled128x64default",
              "message": "Hello from ProtoMQ!"
            }
          }
        }
      }
    },
    {
      "name": "write-hello",
      "description": "Write a test message to the OLED",
      "after": "add-display",
      "delay": 3000,
      "waitFor": "display.addedOrReplaced",
      "topic": "display",
      "send": {
        "display": {
          "write": {
            "name": "oled128x64default",
            "message": "Hello from ProtoMQ!\nFeather S2 OLED\nSH1107 128x64 I2C"
          }
        }
      }
    },
    {
      "name": "write-update",
      "description": "Write an updated status message",
      "after": "write-hello",
      "delay": 5000,
      "topic": "display",
      "send": {
        "display": {
          "write": {
            "name": "oled128x64default",
            "message": "Feather S2 Test OK\nOLED 0x3C ready\nSH1107 FeatherWing"
          }
        }
      }
    }
  ]
}
